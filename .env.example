# ════════════════════════════════════════════════════════════════════════════
# Container Runtime
# ════════════════════════════════════════════════════════════════════════════

# Container runtime for agent sandboxing (default: runc)
# Set to 'runsc' for gVisor sandboxing (stronger isolation, ~10-20% overhead)
# Requires gVisor to be installed: https://gvisor.dev/docs/user_guide/install/
# CONTAINER_RUNTIME=runsc




# ════════════════════════════════════════════════════════════════════════════
# ════════════════════════════════════════════════════════════════════════════
# Zulip Integration
# ════════════════════════════════════════════════════════════════════════════

# Optional: Direct mount Zulip's uploads directory instead of downloading files.
# If set, NanoClaw will mount this path directly into agent containers at /user_uploads,
# providing zero-copy access to Zulip attachments with paths that match Zulip's URL structure.
#
# This means:
#   - Zulip URL: /user_uploads/2/a1/abc123/file.pdf
#   - Container path: /user_uploads/2/a1/abc123/file.pdf
#   - Agent can easily construct URLs and understand file locations
#
# To find your Zulip uploads path:
#   1. Find Zulip volume: docker volume ls | grep zulip
#   2. Inspect volume: docker volume inspect <volume-name> --format '{{ .Mountpoint }}'
#   3. Append /uploads to the mountpoint path
#
# For homelab compose setup (../compose/zulip.yml):
#   ZULIP_UPLOADS_PATH=/var/lib/docker/volumes/homelab_zulip_data/_data/uploads
#
# Or verify with:
#   docker volume inspect homelab_zulip_data --format '{{ .Mountpoint }}'
#   # Then append /uploads to the result
#
# If unset, files will be downloaded to data/uploads/ (slower but works everywhere)
# ZULIP_UPLOADS_PATH=

# Zulip Git Stream Name (default: git)
# The stream name where Forgejo events should be posted via the webhook proxy.
# Topics are created per repository (e.g., #git > my-repo).
# ZULIP_GIT_STREAM=git


# ════════════════════════════════════════════════════════════════════════════
# Forgejo Integration
# ════════════════════════════════════════════════════════════════════════════

# Forgejo server URL (no trailing slash)
# Examples:
#   http://localhost:3000        - Forgejo in Docker on same machine
#   https://forgejo.example.com  - Remote Forgejo server
#   https://git.ts.net           - Forgejo via Tailscale
#
# The credential proxy uses this URL to forward API requests.
# Containers automatically transform localhost → host.docker.internal for git operations.
# FORGEJO_URL=http://localhost:3000

# Personal access token for Forgejo API and git access
# Generate at: <FORGEJO_URL>/user/settings/applications
#
# Required permissions:
#   - read:repository (read repo data, clone repos)
#   - write:repository (push changes)
#   - read:issue (read PRs and issues)
#   - write:issue (create and update PRs)

# Forgejo Webhook Proxy URL
# URL of the Zulip webhook proxy that receives Forgejo webhooks
# and forwards them to Zulip with proper formatting.
# Default: http://homelab_forgejo_zulip_proxy:8080
# FORGEJO_WEBHOOK_PROXY_URL=http://homelab_forgejo_zulip_proxy:8080

# Forgejo Webhook Secret (HMAC)
# Secret key used to sign and validate Forgejo webhooks.
# This ensures webhooks are authentic and haven't been tampered with.
# Generate a strong random secret: openssl rand -hex 32
# FORGEJO_WEBHOOK_SECRET=

TELEGRAM_BOT_TOKEN=
